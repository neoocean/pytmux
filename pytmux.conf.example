# pytmux 설정 예시
# ~/.config/pytmux/config 또는 ~/.pytmux.conf 로 복사해 사용한다.
# (또는 PYTMUX_CONFIG 환경변수로 경로 지정)

# prefix 키를 Ctrl-a 로 변경 (기본: Ctrl-b)
set prefix C-a

# 마우스 사용 (on/off)
set mouse on

# 상태줄 색상(미지정 시 p4v-tui 와 동일한 textual-dark 테마 색을 사용)
# set status-bg green
# set status-fg black

# 스크롤백(copy) 모드 키 스타일: vi 또는 emacs
set mode-keys vi

# 상단 탭바: always = 탭이 하나여도 항상 표시 (기본 auto: 탭 2개 이상일 때만)
set tab-bar always

# 상태줄 포맷(#S 세션, #h 짧은 호스트, #H 호스트, #{pane_title}, %H:%M 등 strftime)
set status-left " [#S] "
set status-right " #{pane_title}#h %H:%M %d-%b-%y "

# prefix 후 키 바인딩: bind <key> <command...>
# (command 는 명령 프롬프트(:)에서 쓰는 것과 동일한 구문)
bind | split-window -h
bind - split-window -v
bind r rename-window
bind k kill-pane
